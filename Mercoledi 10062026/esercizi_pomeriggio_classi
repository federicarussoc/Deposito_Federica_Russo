# Esercizio 3

class ContoCorrente:

    def __init__(self, intestatario, saldo = 0): #costruttore della classe
        self.intestatario = intestatario
        self.saldo = saldo

    def deposita(self, importo): #metodo di istanza
        if importo <= 0:
            print("Errore: importo inferiore o uguale a zero")
        else:
            self.saldo += importo
        
    def preleva(self, importo): #metodo di istanza

        if self.saldo < importo :
            print("Errore: saldo non sufficiente")
        else:
            self.saldo -= importo

    def stampa_saldo(self): #metodo di istanza
        print(f"Il saldo di {self.intestatario} è: {self.saldo}€")


